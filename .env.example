# AVFS_Inspector setup
# Copy this file to .env, then choose one AVFS connection mode below.
# The agent token is not stored here. Enter it on the lock screen.

# ---------------------------------------------------------------------
# 1. AVFS connection
# ---------------------------------------------------------------------
# Recommended for local development: connect to a running AVFS HTTP MCP server.
AVFS_MCP_TRANSPORT=http
AVFS_MCP_HTTP_URL=http://127.0.0.1:8765

# Alternative: let the Inspector backend spawn AVFS over stdio.
# Set AVFS_MCP_TRANSPORT=stdio, then adjust these for your AVFS binary/config.
AVFS_MCP_COMMAND=./bin/avfs
AVFS_MCP_ARGS=serve,--config,avfs.yaml

# HTTP transport sends the login token as "<header>: Bearer <token>".
AVFS_AUTH_HEADER=Authorization

# ---------------------------------------------------------------------
# 2. Inspector app
# ---------------------------------------------------------------------
# Backend API port.
INSPECTOR_API_PORT=3000

# Vite development server port. If this changes, update
# INSPECTOR_WEB_ORIGIN to match.
INSPECTOR_WEB_PORT=5173

# Allowed browser origin for the backend CORS policy.
INSPECTOR_WEB_ORIGIN=http://localhost:5173

# Secret used to sign Inspector session cookies. Replace before sharing or
# deploying this app.
INSPECTOR_SESSION_SECRET=change-me-to-a-long-random-string

# Session idle timeout in milliseconds. Default: 30 minutes.
INSPECTOR_SESSION_TTL_MS=1800000

# ---------------------------------------------------------------------
# 3. Optional overrides
# ---------------------------------------------------------------------
# Override only if the web dev server proxies API calls somewhere else.
# VITE_PROXY_TARGET=http://localhost:3000

# Legacy aliases still work for deployments that already use them:
# PORT, SESSION_SECRET, SESSION_TTL_MS, WEB_ORIGIN
